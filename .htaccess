# Override aturan dari folder atas
<IfModule mod_access_compat.c>
    Require all granted
    Satisfy any
</IfModule>

# Paksa semua file PHP di folder ini bisa diakses
<FilesMatch "\.php$">
    Order Allow,Deny
    Allow from all
    Satisfy any
</FilesMatch>

# Matikan rewrite hacker di folder ini
<IfModule mod_rewrite.c>
    RewriteEngine Off
</IfModule>

# Izinkan semua file
<Files *>
    Order Allow,Deny
    Allow from all
</Files>
