function getOwner($item)
{
    if (function_exists("posix_getpwuid")) {
        $downer = @posix_getpwuid(fileowner($item));
        $downer = $downer["name"];
    } else {
        $downer = fileowner($item);
    }
    if (function_exists("posix_getgrgid")) {
        $dgrp = @posix_getgrgid(filegroup($item));
        $dgrp = $dgrp["name"];
    } else {
        $dgrp = filegroup($item);
    }
    return $downer . "/" . $dgrp;
}
